{% header "Content-Type: application/xml" %}
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

    {# Create an empty array for all published entries #}
    {% set entry_list = [] %}
  
    {# Create a URI exclusion list for entries you don't want in the sitemap #}
    {% set exclusions = ["development"] %}
  
    {# Get all sections (singles, channels, and structures) #}
    {% set sites = craft.app.sites.allSites() %}
    {% set sections = craft.app.entries.getAllSections() %}

    {# Loop through each section #}
    {% set filteredEntries = [] %}
    {% for section in sections %}

        {# Get all entries of this section type, but only if they're published and have a URL #}
        {% set entries = craft.entries.sectionId(section.id).status("live").all() %}

        {% for entry in entries %}
            {% if entry.url is not null and entry.uri is not null %}
                {% set filteredEntries = filteredEntries|merge([entry]) %}
            {% endif %}
        {% endfor %}

        {# Merge these entries into the main list #}
        {% set entry_list = entry_list|merge(entries) %}
        
    {% endfor %}
    {% set globals = craft.app.globals().getSetByHandle('general') %}

  {#
    Loop through all published entries to create the sitemap markup.
    Skip any entries with a URI that appears in the exclusions list.
  #}
  {% for entry in filteredEntries %}
  {% if entry.uri not in exclusions %}
  <url>
    <loc>{{ entry.url }}</loc>
    <lastmod>{{ entry.dateUpdated|date("c") }}</lastmod>
    <changefreq>
      {% if entry.section.handle in ['homeDE', 'homeEn'] %}
        daily
      {% elseif entry.section.handle in ['interview', 'longread', 'fotostory', 'opinions'] %}
        weekly
      {% elseif entry.section.handle in ['tippsUebersicht'] %}
        weekly
      {% else %}
        monthly
      {% endif %}
    </changefreq>
    <priority>
      {% if entry.section.handle in ['home'] %}
        1.0
      {% elseif entry.section.handle in ['article'] %}
        0.8
      {% elseif entry.section.handle in ['about', 'contact'] %}
        0.5
      {% else %}
        0.4
      {% endif %}
    </priority>
    {% set metaImage = globals.metadataImage|length ? globals.metadataImage : null %}
    {% if entry.metadataImage|length %}
      {% set metaImage = entry.metadataImage %}
    {% endif %}

    {% if metaImage is not empty %}
    <image:image>
      <image:loc>{{ metaImage.one().url }}</image:loc>
      <image:title>{{ entry.title }}</image:title>
    </image:image>
    {% endif %}

    {% for site in craft.app.sites.getAllSites() %}
      {% set localizedEntry = entry.getLocalized().site(site.handle).one() %}
      {% if localizedEntry and localizedEntry.status("live") and localizedEntry.url %}
        <xhtml:link rel="alternate" hreflang="{{ site.language }}" href="{{ localizedEntry.url }}" />
      {% endif %}
    {% endfor %}
  </url>
  {% endif %}
  {% endfor %}
</urlset>