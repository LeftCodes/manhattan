{% set image = image.one() ?? null %}
{% set classes = classes ?? "" %}
{% set size = size ?? 'image600x' %}
{% set alt = alt ?? image.alt ?? image.title ?? '' %}

{% if image %}
	<picture class="picture">
		<source media="(min-width: 900px)" srcset="{{ image.getUrl('image1600x') }}">
		<source media="(min-width: 600px)" srcset="{{ image.getUrl('image800x') }}">
		<source media="(min-width: 400px)" srcset="{{ image.getUrl('image600x') }}">

		<img src="{{ image.getUrl(size) }}" alt="{{ alt }}" loading="lazy" decoding="async">
	</picture>
{% endif %}
